# SMTP Configuration
# Diese Datei NIEMALS in Git hochladen (ist bereits in .gitignore)
# Fülle die Daten hier aus, damit das Kontaktformular funktioniert.

SMTP_HOST=your.smtpserver.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-password
SMTP_FROM=your-email@domain.com
SMTP_TO=your-email@domain.com
